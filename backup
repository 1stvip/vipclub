}

// 1. تهيئة Firebase
function initializeFirebase() {
    try {
        if (!firebase.apps.length) {
            firebase.initializeApp(firebaseConfig);
        }
        database = firebase.database();
        
        showAlert('✅ تم الاتصال بـ Firebase Realtime Database', 'success');
        
        // اختبار الاتصال
        testConnection();
        
        // تحميل البيانات
        loadUsers();
        
        // الاستماع للمستخدمين الجدد
        listenForNewUsers();
        
        // الاستماع للتحديثات الأخرى
        listenForUpdates();
        
    } catch (error) {
        showAlert('❌ خطأ في الاتصال: ' + error.message, 'error');
    }
}

// الاستماع للمستخدمين الجدد
function listenForNewUsers() {
    if (!database) return;
    
    database.ref('users').on('child_added', (snapshot) => {
        const newUser = snapshot.val();
        const userId = snapshot.key;
        
        console.log('👤 تم إضافة مستخدم جديد:', newUser.username);
        
        // عرض إشعار
        showNewUserNotification(newUser);
        
        // إعادة تحميل البيانات
        loadUsers();
        
        // تشغيل صوت إشعار
        playNotificationSound();
    });
}

// 2. إشعار إضافة مستخدم جديد
function showNewUserNotification(user) {
    const notification = document.getElementById('newUserNotification');
    const userInfo = document.getElementById('newUserInfo');
    
    userInfo.innerHTML = `
        👤 ${user.username} 
        🔢 ID: ${user.numericId || 'N/A'}
        📅 ${new Date(user.createdAt || new Date()).toLocaleTimeString('ar-EG')}
    `;
    
    notification.style.display = 'block';
    
    setTimeout(() => {
        notification.style.display = 'none';
    }, 5000);
}

