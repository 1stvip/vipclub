// 19. تحميل المستخدمين المحذوفين
async function loadDeletedUsers() {
    const deletedBody = document.getElementById('deletedUsersBody');
    
    if (!database) {
        deletedBody.innerHTML = '<tr><td colspan="7">❌ Firebase غير متصل</td></tr>';
        return;
    }
    
    try {
        const snapshot = await database.ref('deleted_users').once('value');
        
        if (!snapshot.exists()) {
            deletedBody.innerHTML = `
                <tr>
                    <td colspan="7" style="text-align: center; padding: 40px;">
                        <div style="font-size: 48px; margin-bottom: 15px;">🗑️</div>
                        <h4 style="color: #666;">لا يوجد مستخدمين محذوفين مؤقتاً</h4>
                        <p style="color: #999; margin-top: 10px;">جميع الحسابات المحذوفة مؤقتاً ستظهر هنا</p>
                    </td>
                </tr>
            `;
            return;
        }
        
        let html = '';
        const deletedData = snapshot.val();
        
        for (const deletedId in deletedData) {
            const user = deletedData[deletedId];
            
            let dateDisplay = '---';
            if (user.deletedAt) {
                try {
                    dateDisplay = new Date(user.deletedAt).toLocaleString('ar-EG');
                } catch (e) {
                    dateDisplay = user.deletedAt;
                }
            }
            
            let deleteType = 'مؤقت';
            let typeClass = 'status-temporary';
            
            if (user.reason && user.reason.includes('حذف نهائي')) {
                deleteType = 'نهائي';
                typeClass = 'status-permanent';
            }
            
            html += `
                <tr>
                    <td>
                        <div style="font-family: monospace; font-size: 12px; background: #f1f5f9; padding: 5px; border-radius: 5px;">
                            ${user.numericId || '---'}
                        </div>
                    </td>
                    <td>
                        <div style="font-weight: bold;">${user.username || '---'}</div>
                    </td>
                    <td>
                        <div>📱 ${user.phone || '---'}</div>
                        <div>📧 ${user.email || '---'}</div>
                    </td>
                    <td>
                        <div style="font-size: 11px;">${dateDisplay}</div>
                    </td>
                    <td>
                        <div style="font-size: 11px; color: #666;">${user.reason || '---'}</div>
                    </td>
                    <td>
                        <div class="deleted-status ${typeClass}">${deleteType}</div>
                    </td>
                    <td>
                        <div style="display: flex; gap: 5px; justify-content: center;">
                            <button class="action-btn" style="background: #10b981; color: white;" onclick="restoreUser('${deletedId}', ${user.numericId})" title="استعادة المستخدم">
                                🔄 استعادة
                            </button>
                            <button class="action-btn" style="background: #ef4444; color: white;" onclick="permanentDelete('${deletedId}', '${user.username}')" title="حذف نهائي">
                                🗑️ حذف نهائي
                            </button>
                        </div>
                    </td>
                </tr>
            `;
        }
        
        deletedBody.innerHTML = html;
        
    } catch (error) {
        deletedBody.innerHTML = `<tr><td colspan="7">❌ خطأ: ${error.message}</td></tr>`;
        showAlert('❌ خطأ في تحميل المستخدمين المحذوفين: ' + error.message, 'error');
    }
}

// 20. استعادة مستخدم محذوف
async function restoreUser(deletedId, numericId) {
    if (!confirm('هل تريد استعادة هذا المستخدم؟')) return;
    
    try {
        // جلب بيانات المستخدم المحذوف
        const snapshot = await database.ref('deleted_users/' + deletedId).once('value');
        const deletedUser = snapshot.val();
        
        if (!deletedUser) {
            showAlert('❌ لم يتم العثور على بيانات المستخدم', 'error');
            return;
        }
        
        // إنشاء مستخدم جديد بنفس البيانات
        const newUserRef = database.ref('users').push();
        
        await newUserRef.set({
            numericId: numericId,
            username: deletedUser.username,
            password: deletedUser.password || '123456',
            nickname: deletedUser.nickname || deletedUser.username,
            email: deletedUser.email || '',
            phone: deletedUser.phone || '',
            balanceEGP: deletedUser.balanceEGP || 0,
            balanceUSD: deletedUser.balanceUSD || 0,
            isBanned: deletedUser.isBanned || false,
            banReason: deletedUser.banReason || '',
            banExpiry: deletedUser.banExpiry || '',
            createdAt: new Date().toISOString(),
            updatedAt: new Date().toISOString()
        });
        
        // حذف من جدول المحذوفين المؤقت
        await database.ref('deleted_users/' + deletedId).remove();
        
        showAlert(`✅ تم استعادة المستخدم ${deletedUser.username} بنجاح`, 'success');
        
        // إعادة تحميل القوائم
        loadDeletedUsers();
        loadUsers();
        
        // العودة للجدول الرئيسي
        setTimeout(() => {
            showDeletedUsersSection();
        }, 1000);
        
    } catch (error) {
        showAlert('❌ خطأ في استعادة المستخدم: ' + error.message, 'error');
    }
}

// 21. حذف نهائي من جدول المحذوفين المؤقت
async function permanentDelete(deletedId, username) {
    if (!confirm(`هل تريد حذف المستخدم ${username} نهائياً من قاعدة البيانات؟\n\n⚠️ هذا الإجراء لا يمكن التراجع عنه!`)) return;
    
    try {
        // نقل إلى جدول الحذف النهائي
        const snapshot = await database.ref('deleted_users/' + deletedId).once('value');
        const deletedUser = snapshot.val();
        
        if (deletedUser) {
            await database.ref('permanent_deleted_users').push({
                ...deletedUser,
                permanentlyDeletedAt: new Date().toISOString(),
                permanentlyDeletedBy: 'admin'
            });
        }
        
        // حذف نهائي
        await database.ref('deleted_users/' + deletedId).remove();
        
        showAlert(`✅ تم حذف المستخدم ${username} نهائياً`, 'success');
        loadDeletedUsers();
        
    } catch (error) {
        showAlert('❌ خطأ في الحذف النهائي: ' + error.message, 'error');
    }
}

// 22. عرض الرسائل
function showAlert(message, type) {
    const container = document.getElementById('alertContainer');
    const alertDiv = document.createElement('div');
    alertDiv.className = `alert alert-${type}`;
    alertDiv.innerHTML = `
        <span>${type === 'success' ? '✅' : type === 'error' ? '❌' : 'ℹ️'}</span>
        <div style="flex: 1;">${message}</div>
        <button onclick="this.parentElement.remove()" style="background: none; border: none; color: inherit; cursor: pointer; font-size: 16px;">×</button>
    `;
    
    container.insertBefore(alertDiv, container.firstChild);
    
    setTimeout(() => {
        if (alertDiv.parentElement) {
            alertDiv.remove();
        }
    }, 10000);
}

// 23. إظهار معلومات الاتصال
function showConnectionInfo() {
    const infoDiv = document.getElementById('connectionInfo');
    infoDiv.style.display = infoDiv.style.display === 'none' ? 'block' : 'none';
}

