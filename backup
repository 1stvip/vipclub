<!DOCTYPE html>
<html>
<head>
    <title>اختبار Firebase</title>
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-database.js"></script>
</head>
<body>
    <h1>اختبار Firebase</h1>
    <div id="result"></div>

<script>
// نفس الإعدادات
const firebaseConfig = {
    apiKey: "AIzaSyAX0jz_yOGagteO5R5ZHji1ZG44fk--Zvs",
    authDomain: "stvipclub.firebaseapp.com",
    databaseURL: "https://stvipclub-default-rtdb.europe-west1.firebasedatabase.app/",
    projectId: "stvipclub",
    storageBucket: "stvipclub.firebasestorage.app",
    messagingSenderId: "526607326044",
    appId: "1:526607326044:web:6af53db123ae02c7193f99",
    measurementId: "G-QZQMQCH9N9"
};

// تهيئة Firebase
firebase.initializeApp(firebaseConfig);
const database = firebase.database();

// جلب البيانات
database.ref('users').once('value')
    .then((snapshot) => {
        const data = snapshot.val();
        document.getElementById('result').innerHTML = 
            '<pre>' + JSON.stringify(data, null, 2) + '</pre>';
        console.log('✅ نجاح:', data);
    })
    .catch((error) => {
        document.getElementById('result').innerHTML = '❌ خطأ: ' + error.message;
        console.error('❌ خطأ:', error);
    });
</script>
</body>
</html>
