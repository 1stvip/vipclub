}

// 1. تهيئة Firebase (معدلة)
async function initializeFirebase() {
    try {
        // 🔴 مهم: احذف أي Firebase قديم
        if (firebase.apps.length > 0) {
            console.log('🔄 جاري حذف Firebase القديم...');
            await firebase.app().delete();
        }
        
        // تهيئة Firebase من جديد
        firebase.initializeApp(firebaseConfig);
        database = firebase.database();
        
        console.log('✅ Firebase متصل بالمشروع الجديد:', firebaseConfig.projectId);
        showAlert(`✅ تم الاتصال بمشروع ${firebaseConfig.projectId}`, 'success');
        
        // اختبار الاتصال
        testConnection();
        
        // تحميل البيانات
        loadUsers();
        
    } catch (error) {
        console.error('❌ خطأ:', error);
        showAlert('❌ خطأ في الاتصال: ' + error.message, 'error');
    }
}
